{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenUse",
  "version": "0.2.0",
  "identifier": "com.shallowdream.screenuse",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ScreenUse",
        "width": 1180,
        "height": 820,
        "minWidth": 760,
        "minHeight": 600,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "低占用个人电脑活动时间账本",
    "longDescription": "ScreenUse uses foreground-window, browser-tab and editor metadata to classify personal computer time locally without screenshots. Optional AI only reviews uncertain sessions.",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
