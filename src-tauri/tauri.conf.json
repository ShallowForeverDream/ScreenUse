{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenUse",
  "version": "0.1.0",
  "identifier": "com.shallowdream.screenuse",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ScreenUse",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "智能个人活动时间追踪工具",
    "longDescription": "ScreenUse records desktop activity, analyzes low-frequency screen chunks and metadata, and attributes time to projects, tasks and activities.",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
