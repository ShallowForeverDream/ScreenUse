+++ b/extensions/vscode/package.json
@@ -0,0 +1,35 @@
+{
+  "name": "screenuse-vscode-collector",
+  "displayName": "ScreenUse VS Code Context",
+  "description": "Sends deduplicated workspace, active file and Git branch metadata to local ScreenUse.",
+  "version": "0.2.0",
+  "publisher": "screenuse",
+  "engines": {
+    "vscode": "^1.92.0"
+  },
+  "categories": [
+    "Other"
+  ],
+  "activationEvents": [
+    "onStartupFinished",
+    "onCommand:screenuse.syncNow"
+  ],
+  "main": "./dist/extension.js",
+  "contributes": {
+    "commands": [
+      {
+        "command": "screenuse.syncNow",
+        "title": "ScreenUse: Sync Context Now"
+      }
+    ]
+  },
+  "scripts": {
+    "compile": "tsc -p ./",
+    "watch": "tsc -watch -p ./"
+  },
+  "devDependencies": {
+    "@types/vscode": "^1.92.0",
+    "@types/node": "^22.0.0",
+    "typescript": "^5.7.2"
+  }
+}
