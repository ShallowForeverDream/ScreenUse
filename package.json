{
  "name": "screenuse",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-dev.ps1",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-build.ps1",
    "check": "tsc --noEmit",
    "cargo:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-check.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.6",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2"
  }
}
