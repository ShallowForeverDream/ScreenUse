+    debounce = setTimeout(() => void sendActivity(eventKind, force), 500);
+  };
+
+  context.subscriptions.push(
+    vscode.commands.registerCommand('screenuse.syncNow', () => schedule('manual', true)),
+    vscode.window.onDidChangeActiveTextEditor(() => schedule('active-editor')),
+    vscode.workspace.onDidChangeWorkspaceFolders(() => schedule('workspace')),
+    vscode.window.onDidOpenTerminal(() => schedule('terminal')),
+    vscode.window.onDidCloseTerminal(() => schedule('terminal')),
+    vscode.debug.onDidStartDebugSession(() => schedule('debug-start')),
+    vscode.debug.onDidTerminateDebugSession(() => schedule('debug-stop')),
+  );
+
+  heartbeat = setInterval(() => schedule('heartbeat'), HEARTBEAT_MS);
+  schedule('activate', true);
+}
+
+export function deactivate() {
+  if (heartbeat) clearInterval(heartbeat);
+  if (debounce) clearTimeout(debounce);
+}
+
+async function sendActivity(eventKind: string, force = false) {
+  const editor = vscode.window.activeTextEditor;
+  const workspace = (vscode.workspace.workspaceFolders || []).slice(0, 3).map((folder) => ({
+    name: folder.name,
+    path: folder.uri.fsPath,
+  }));
+  const gitBranch = await detectGitBranch(workspace[0]?.path);
+  const payload = {
+    source: 'vscode-context',
+    capturedAt: new Date().toISOString(),
+    eventKind,
+    workspace,
+    activeFile:
+      editor?.document.uri.scheme === 'file'
+        ? editor.document.uri.fsPath
+        : editor?.document.uri.toString(),
+    languageId: editor?.document.languageId,
+    gitBranch,
+    terminalCount: vscode.window.terminals.length,
+    debugActive: vscode.debug.activeDebugSession?.name || null,
+  };
+  const fingerprint = JSON.stringify([
+    workspace,
+    payload.activeFile,
+    payload.languageId,
+    payload.gitBranch,
+    payload.terminalCount,
+    payload.debugActive,
+  ]);
+  if (!force && fingerprint === lastFingerprint && Date.now() - lastSentAt < HEARTBEAT_MS) {
+    return;
+  }
+
+  try {
+    const response = await fetch(ENDPOINT, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify(payload),
+    });
+    if (response.ok) {
+      lastFingerprint = fingerprint;
+      lastSentAt = Date.now();
+    }
+  } catch {
+    // ScreenUse may not be running; never interrupt the editor.
+  }
+}
+
+async function detectGitBranch(workspacePath?: string): Promise<string | null> {
+  if (!workspacePath) return null;
+  const git = vscode.extensions.getExtension('vscode.git')?.exports;
+  const api = git?.getAPI?.(1);
+  const repo =
+    api?.repositories?.find((candidate: any) => candidate.rootUri?.fsPath === workspacePath) ||
+    api?.repositories?.[0];
+  return repo?.state?.HEAD?.name || null;
+}
