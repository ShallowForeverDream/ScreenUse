{
  "name": "screenuse-vscode-collector",
  "displayName": "ScreenUse VS Code Collector",
  "description": "Sends workspace, active file and Git branch metadata to ScreenUse. It does not read file body.",
  "version": "0.1.0",
  "publisher": "screenuse",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onDidChangeActiveTextEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "screenuse.syncNow",
        "title": "ScreenUse: Sync Activity Now"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.92.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2"
  }
}