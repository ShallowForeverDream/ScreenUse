{
  "name": "screenuse-vscode-collector",
  "displayName": "ScreenUse Editor Context",
  "description": "Silently sends the active workspace, file, language and Git branch metadata to the local ScreenUse app. It never reads file contents.",
  "version": "0.3.0",
  "publisher": "screenuse",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onDidChangeActiveTextEditor",
    "onCommand:screenuse.syncNow"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "screenuse.syncNow",
        "title": "ScreenUse: Sync Editor Context Now"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.92.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2"
  }
}
