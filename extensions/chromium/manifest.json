{
  "manifest_version": 3,
  "name": "ScreenUse Active Tab Context",
  "version": "0.6.0",
  "description": "Sends the active page, selected AI conversation title and compact URL to the local ScreenUse app.",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:51247/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["page-context.js", "media-state.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScreenUse"
  }
}
