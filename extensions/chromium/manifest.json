{
  "manifest_version": 3,
  "name": "ScreenUse Active Tab Context",
  "version": "0.2.0",
  "description": "Sends only the active tab title and compact URL to the local ScreenUse app.",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:51247/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScreenUse"
  }
}
