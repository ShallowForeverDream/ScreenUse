+                ("tauri", 4),
+                ("terminal", 3),
+                ("powershell", 3),
+                ("cmd.exe", 3),
+                (".rs", 3),
+                (".tsx", 3),
+                (".ts", 2),
+                (".py", 3),
+                ("debug", 2),
+            ],
+        ),
+        (
+            "写作",
+            &[
+                ("winword", 5),
+                ("word.exe", 5),
+                ("wps", 5),
+                ("obsidian", 4),
+                ("typora", 4),
+                ("notion", 3),
+                ("markdown", 3),
+                ("写作", 4),
+                ("文档", 2),
+                ("草稿", 3),
+                ("论文写作", 5),
+            ],
+        ),
+        (
+            "学习",
+            &[
+                ("acrobat", 4),
+                ("pdf", 3),
+                ("arxiv", 4),
+                ("知网", 4),
+                ("课程", 4),
+                ("教程", 4),
+                ("lecture", 4),
+                ("course", 4),
+                ("documentation", 3),
+                ("docs.", 2),
