+    pub fn record_export(&self, format: &str, path: &Path) -> Result<()> {
+        let conn = self.conn.lock();
+        conn.execute(
+            "INSERT INTO export_records(id,format,path,created_at) VALUES(?1,?2,?3,?4)",
+            params![
+                Uuid::new_v4().to_string(),
+                format,
+                path.display().to_string(),
+                now()
+            ],
+        )?;
+        Ok(())
+    }
+
+    pub fn backup_now(&self, target_dir: Option<String>) -> Result<PathBuf> {
+        let dir = target_dir
+            .map(PathBuf::from)
+            .unwrap_or_else(|| self.data_dir.join("backups"));
+        fs::create_dir_all(&dir)?;
+        let target = dir.join(format!(
+            "screenuse-backup-{}.db",
+            Utc::now().format("%Y%m%d-%H%M%S")
+        ));
+        {
+            let conn = self.conn.lock();
+            conn.execute_batch("PRAGMA wal_checkpoint(FULL);")?;
+        }
+        fs::copy(&self.db_path, &target)?;
+        Ok(target)
+    }
+
+    pub fn cleanup_media_cache(&self) -> Result<u32> {
+        let limit = self.get_settings()?.temp_storage_limit_gb.max(1) as u64 * 1_073_741_824;
+        let mut current_size = dir_size(self.media_cache_dir());
+        if current_size <= limit {
+            return Ok(0);
+        }
+        let conn = self.conn.lock();
+        let rows = {
+            let mut stmt = conn.prepare(
+                "SELECT id,path,status FROM media_chunks\
+                 ORDER BY CASE status WHEN 'analyzed' THEN 0 WHEN 'deleted' THEN 1\
+                 WHEN 'downgraded' THEN 2 ELSE 3 END,started_at ASC",
+            )?;
+            let rows = stmt.query_map([], |row| {
+                Ok((
+                    row.get::<_, String>(0)?,
+                    row.get::<_, String>(1)?,
+                    row.get::<_, String>(2)?,
+                ))
+            })?;
+            collect_rows(rows)?
+        };
+        drop(conn);
+        let mut deleted = 0u32;
+        for (id, path, status) in rows {
+            if current_size <= limit {
+                break;
+            }
+            if matches!(
+                status.as_str(),
+                "recording" | "running" | "pending-analysis" | "pending"
+            ) {
+                continue;
+            }
+            let path = PathBuf::from(path);
+            let before = path_size(&path);
+            if path.is_dir() {
+                let _ = fs::remove_dir_all(&path);
+            } else if path.is_file() {
+                let _ = fs::remove_file(&path);
+            }
+            if before > 0 {
+                current_size = current_size.saturating_sub(before);
+                let conn = self.conn.lock();
+                conn.execute(
+                    "UPDATE media_chunks SET status='deleted' WHERE id=?1",
+                    params![id],
+                )?;
+                deleted += 1;
+            }
+        }
+        Ok(deleted)
+    }
+}
+
+fn map_session_row(row: &rusqlite::Row<'_>) -> rusqlite::Result<WorkSession> {
+    let evidence_json: String = row.get(10)?;
+    Ok(WorkSession {
+        id: row.get(0)?,
+        started_at: row.get(1)?,
+        ended_at: row.get(2)?,
+        project_id: row.get(3)?,
+        project_name: row.get(4)?,
+        task_id: row.get(5)?,
+        task_title: row.get(6)?,
+        category: row.get(7)?,
+        summary: row.get(8)?,
+        confidence: row.get(9)?,
+        evidence: parse_json(&evidence_json),
+        user_confirmed: row.get::<_, i64>(11)? != 0,
+        source: row.get(12)?,
+    })
+}
+
+fn map_raw_event_row(row: &rusqlite::Row<'_>) -> rusqlite::Result<RawActivityEvent> {
+    let input_stats_json: String = row.get(8)?;
+    let metadata_json: String = row.get(9)?;
+    Ok(RawActivityEvent {
+        id: row.get(0)?,
+        source: row.get(1)?,
+        timestamp: row.get(2)?,
+        app: row.get(3)?,
+        window_title: row.get(4)?,
+        url: row.get(5)?,
+        file_path: row.get(6)?,
+        workspace: row.get(7)?,
+        input_stats: parse_json(&input_stats_json),
+        metadata: serde_json::from_str(&metadata_json).unwrap_or_else(|_| json!({})),
+    })
+}
+
+fn is_primary_source(source: &str) -> bool {
+    matches!(source, "windows-foreground" | "desktop-foreground")
+}
+
+fn is_browser_app(app: &str) -> bool {
+    [
+        "chrome", "msedge", "chromium", "brave", "vivaldi", "opera", "arc", "firefox",
+    ]
+    .iter()
+    .any(|needle| app.contains(needle))
+}
+
+fn is_editor_app(app: &str) -> bool {
+    [
+        "code.exe",
+        "code - insiders",
+        "cursor",
+        "codium",
+        "devenv",
+        "idea",
+        "pycharm",
+        "webstorm",
+        "rustrover",
+    ]
+    .iter()
+    .any(|needle| app.contains(needle))
+}
+
+fn compact_event(event: &mut RawActivityEvent) {
+    event.source = truncate(&event.source, 80);
+    event.app = event.app.take().map(|value| truncate(&value, 120));
+    event.window_title = event
+        .window_title
+        .take()
+        .map(|value| truncate(&collapse_whitespace(&value), 512));
+    event.url = event.url.take().map(|value| truncate(&value, 1024));
+    event.file_path = event.file_path.take().map(|value| truncate(&value, 512));
+    event.workspace = event.workspace.take().map(|value| truncate(&value, 512));
+    event.input_stats.shortcut_events.truncate(12);
+}
+
+fn evidence_for_event(event: &RawActivityEvent) -> Vec<EvidenceItem> {
+    let mut evidence = Vec::new();
+    let mut push = |kind: &str, label: &str, value: Option<&str>, weight: f32| {
+        if let Some(value) = value.map(str::trim).filter(|value| !value.is_empty()) {
+            evidence.push(EvidenceItem {
+                kind: kind.into(),
+                label: label.into(),
+                value: truncate(value, 240),
+                weight,
+            });
+        }
+    };
+    push("workspace", "工作区", event.workspace.as_deref(), 0.92);
+    push("url", "网页", event.url.as_deref(), 0.86);
+    push("file", "文件", event.file_path.as_deref(), 0.84);
+    push("window", "窗口", event.window_title.as_deref(), 0.72);
+    push("app", "应用", event.app.as_deref(), 0.55);
+    evidence.truncate(5);
+    evidence
+}
+
+fn event_haystack(event: &RawActivityEvent) -> String {
+    [
+        event.app.as_deref().unwrap_or_default(),
+        event.window_title.as_deref().unwrap_or_default(),
+        event.url.as_deref().unwrap_or_default(),
+        event.file_path.as_deref().unwrap_or_default(),
+        event.workspace.as_deref().unwrap_or_default(),
+    ]
+    .join(" ")
+    .to_lowercase()
+}
+
+fn rule_matches(matcher: &serde_json::Value, event: &RawActivityEvent, hay: &str) -> bool {
+    let contains = |field: &str, value: &str| {
+        matcher
+            .get(field)
+            .and_then(|item| item.as_str())
+            .map(str::trim)
+            .filter(|needle| !needle.is_empty())
+            .map(|needle| value.to_lowercase().contains(&needle.to_lowercase()))
+            .unwrap_or(false)
+    };
+    contains("keyword", hay)
+        || contains("app", event.app.as_deref().unwrap_or_default())
+        || contains("domain", event.url.as_deref().unwrap_or_default())
+        || contains("url", event.url.as_deref().unwrap_or_default())
+        || contains("path", event.file_path.as_deref().unwrap_or_default())
+        || contains("workspace", event.workspace.as_deref().unwrap_or_default())
+        || contains("title", event.window_title.as_deref().unwrap_or_default())
+}
+
+fn classify_locally(event: &RawActivityEvent, hay: &str) -> (String, i32) {
+    let app = event.app.as_deref().unwrap_or_default().to_lowercase();
+    let title = event
+        .window_title
+        .as_deref()
+        .unwrap_or_default()
+        .to_lowercase();
+    let url = event.url.as_deref().unwrap_or_default().to_lowercase();
+
+    let categories: [(&str, &[(&str, i32)]); 6] = [
+        (
+            "开发",
+            &[
+                ("code.exe", 5),
+                ("visual studio", 5),
+                ("cursor", 5),
+                ("codex", 5),
+                ("github", 3),
